{
  "name": "codex-monorep-template",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "template:init": "node ./tooling/scripts/template-init.mjs",
    "dev": "pnpm --parallel --filter ./apps/api --filter ./apps/web dev",
    "build": "pnpm -r --filter ./apps/api --filter ./apps/web build",
    "lint": "pnpm -r --filter ./apps/api --filter ./apps/web lint",
    "typecheck": "pnpm -r --if-present --filter ./apps/api --filter ./apps/web typecheck",
    "test:template": "node --test ./tooling/scripts/template-init.test.mjs",
    "test": "pnpm run test:template && pnpm -r --if-present --filter ./apps/api --filter ./apps/web test",
    "validate": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "format": "pnpm -r --filter ./apps/api --filter ./apps/web format"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.48.0"
  }
}
